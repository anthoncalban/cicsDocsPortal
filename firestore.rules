rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Simplified Development Rules
    // Allows any authenticated user from @neu.edu.ph to read and write to any collection.
    // Use this for debugging visibility issues.
    
    match /{document=**} {
      allow read, write: if request.auth != null && 
                          request.auth.token.email.matches(".*@neu\\.edu\\.ph$");
    }
  }
}
